body{background-color:#fff;font-family:Verdana,Geneva,Tahoma,sans-serif}a{color:#f72a6e;text-decoration:none}pre{white-space:pre-wrap;word-wrap:break-word}code{white-space:pre-wrap;word-wrap:break-word}#body-container{display:flex;flex-direction:column;justify-content:center;align-items:center}#main-container{max-width:700px;margin:0 auto;overflow-wrap:break-word;word-wrap:break-word;hyphens:auto;display:flex;flex-direction:column;justify-content:center;border:2px solid #eb6894;border-top:none;padding:10px}#menu-container{display:flex;flex-direction:row;align-items:center}#menu-container ul{display:flex;flex-direction:column;justify-content:center;align-items:center;list-style-type:none;font-weight:700}#menu-container ul li{padding-top:1px}#footer-container{display:flex;justify-content:center}#title-container{display:flex;justify-content:center;line-height:0}#select-container{display:flex;justify-content:center;align-items:center;padding-bottom:10px}#header-container{border:2px solid #eb6894;width:100%;max-width:724px;padding:10px;display:flex;justify-content:center;margin:0 auto;box-sizing:border-box}